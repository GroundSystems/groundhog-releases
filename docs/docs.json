{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Groundhog",
  "description": "Install, use, and operate Groundhog.",
  "colors": {
    "primary": "#BC3E1D",
    "light": "#E05A31",
    "dark": "#BC3E1D"
  },
  "logo": {
    "light": "/assets/logo-light.svg",
    "dark": "/assets/logo-dark.svg",
    "href": "https://groundhog.so"
  },
  "favicon": "/assets/favicon.svg",
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Source Sans 3",
    "heading": {
      "family": "Source Serif 4",
      "weight": 500
    }
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "color": {
      "light": "#FAF8F3",
      "dark": "#131009"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Groundhog",
        "href": "https://groundhog.so"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/GroundSystems/groundhog-releases"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Download",
      "href": "https://github.com/GroundSystems/groundhog-releases/releases"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Start here",
        "pages": [
          "index",
          "guides/getting-started"
        ]
      },
      {
        "group": "Use Groundhog",
        "pages": [
          "commands",
          "references/http-api"
        ]
      },
      {
        "group": "Understand the system",
        "pages": [
          "concepts/events",
          "concepts/storage",
          "concepts/warehouse"
        ]
      },
      {
        "group": "Operate a deployment",
        "pages": [
          "references/configuration",
          "operations/deployment",
          "operations/verification-and-recovery"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "references/cli",
          "sdks/python"
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "mcp",
      "cursor"
    ],
    "display": "toc"
  },
  "footer": {
    "socials": {
      "website": "https://groundhog.so",
      "github": "https://github.com/GroundSystems/groundhog-releases"
    },
    "links": [
      {
        "header": "Manual",
        "items": [
          {
            "label": "Getting started",
            "href": "/guides/getting-started"
          },
          {
            "label": "Commands",
            "href": "/commands"
          },
          {
            "label": "HTTP API",
            "href": "/references/http-api"
          }
        ]
      },
      {
        "header": "Groundhog",
        "items": [
          {
            "label": "Website",
            "href": "https://groundhog.so"
          },
          {
            "label": "Releases",
            "href": "https://github.com/GroundSystems/groundhog-releases/releases"
          },
          {
            "label": "Release repository",
            "href": "https://github.com/GroundSystems/groundhog-releases"
          }
        ]
      }
    ]
  }
}
